# Environment variables for development

# ===========================
# Form Backend Configuration
# ===========================
# Choose one provider: appscript, smtp, or third-party

# Apps Script: Only VITE_FORM_SCRIPT_URL required
VITE_FORM_BACKEND=appscript
VITE_FORM_SCRIPT_URL=https://script.google.com/macros/s/AKfycbzZ_MDBYKT1ewKOitoFCTY4zkTSlfj7wFGU60oVHP-A_C6oKcdoJ6MxQZmY-Wzmj8jSbw/exec

# SMTP Backend: Requires SMTP vars + VITE_FORM_API_URL
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-password
# SMTP_FROM=your-email@example.com
# CONTACT_EMAIL=your-email@example.com
# VITE_FORM_API_URL=/api/contact

# Third-party Backend: VITE_FORM_THIRD_PARTY_URL required
# VITE_FORM_THIRD_PARTY_URL=https://formspree.io/f/YOUR_FORM_ID
